{
  "name": "DBSprout Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.0"
    }
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "ms-python.python",
        "ms-python.mypy-type-checker",
        "charliermarsh.ruff",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
          }
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"]
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=dbsprout-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=dbsprout-claude-state-${devcontainerId},target=/home/node/.claude,type=volume",
    "source=${localEnv:HOME}/.claude/settings.json,target=/tmp/.claude-host/settings.json,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/.credentials.json,target=/tmp/.claude-host/credentials.json,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/rules,target=/home/node/.claude/rules,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/commands,target=/home/node/.claude/commands,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/skills,target=/home/node/.claude/skills,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/plugins,target=/tmp/.claude-host/plugins,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/scripts,target=/home/node/.claude/scripts,type=bind,readonly",
    "source=${localEnv:HOME}/bin/claude-watchdog.sh,target=/usr/local/bin/claude-watchdog.sh,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/projects,target=/home/node/.claude/projects,type=bind",
    "source=${localEnv:HOME}/.config/gh,target=/home/node/.config/gh,type=bind",
    "source=${localEnv:HOME}/.gh-token,target=/tmp/.gh-token,type=bind,readonly"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "LINEAR_API_KEY": "${localEnv:LINEAR_API_KEY}",
    "LETTA_API_KEY": "${localEnv:LETTA_API_KEY}",
    "LETTA_AGENT_ID": "${localEnv:LETTA_AGENT_ID}",
    "LETTA_BASE_URL": "${localEnv:LETTA_BASE_URL}"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postCreateCommand": "bash /workspace/.devcontainer/post-create.sh",
  "postStartCommand": "bash /workspace/.devcontainer/sync-plugins.sh && sudo /usr/local/bin/init-firewall.sh",
  "waitFor": "postStartCommand"
}
